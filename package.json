{
  "name": "jster-website-v2",
  "version": "0.0.0",
  "description": "jster.net website",
  "type": "module",
  "main": "index.js",
  "engines": {
    "node": ">=24.11.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20240222.0",
    "@types/node": "24.12.4",
    "gustwind": "0.120.0",
    "highlight.js": "11.11.1",
    "marked": "12.0.0",
    "typescript": "5.3.3",
    "wrangler": "3.114.17"
  },
  "scripts": {
    "build": "gustwind --build --output ./build --route-concurrency 1",
    "build:validate": "gustwind --build --output ./build --route-concurrency 1 --validate",
    "start": "gustwind --develop --port 3000",
    "serve": "gustwind --serve --input ./build --port 3000",
    "pages:dev": "wrangler pages dev build --compatibility-flags=\"nodejs_compat\" --compatibility-date=2024-03-05",
    "compress:cache": "tar -zcf build/cache.tar.gz .gustwind",
    "decompress:cache": "node ./scripts/decompress-cache.mjs",
    "copy:css": "node ./scripts/copy-tailwind-css.mjs",
    "generate:manifest": "node ./scripts/generate-manifest.mjs"
  },
  "keywords": [],
  "author": "Juho Vepsäläinen",
  "license": "MIT",
  "dependencies": {
    "htmlisp": "0.90.0",
    "yaml": "2.9.0",
    "zod": "3.22.4"
  }
}
