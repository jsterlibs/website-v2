{
  "name": "jster-website-v2",
  "version": "0.0.0",
  "description": "jster.net website",
  "type": "module",
  "main": "index.js",
  "engines": {
    "node": ">=24.11.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260603.1",
    "@types/node": "25.9.1",
    "gustwind": "0.151.0",
    "highlight.js": "11.11.1",
    "typescript": "6.0.3",
    "wrangler": "4.97.0"
  },
  "scripts": {
    "build": "gustwind --build --output ./build --progress",
    "build:cloudflare": "gustwind --build --output ./build --cache-from https://jster.net/ --progress",
    "build:validate": "gustwind --build --output ./build --validate --progress",
    "start": "gustwind --develop --port 3000",
    "serve": "gustwind --serve --input ./build --port 3000",
    "pages:dev": "wrangler pages dev build --compatibility-flags=\"nodejs_compat\" --compatibility-date=2024-03-05",
    "check:links": "node ./scripts/check-links.mjs",
    "check:links:external": "node ./scripts/check-links.mjs --external",
    "copy:css": "node ./scripts/copy-tailwind-css.mjs",
    "generate:manifest": "node ./scripts/generate-manifest.mjs",
    "fetch:new-jster": "node ./scripts/fetch-new-jster.mjs"
  },
  "keywords": [],
  "author": "Juho Vepsäläinen",
  "license": "MIT",
  "dependencies": {
    "htmlisp": "0.100.0",
    "satteri": "0.9.4",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  }
}
