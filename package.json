{
  "name": "jster-website-v2",
  "version": "0.0.0",
  "description": "jster.net website",
  "type": "module",
  "main": "index.js",
  "engines": {
    "node": ">=26.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260603.1",
    "@types/node": "25.9.1",
    "gustwind": "0.160.0",
    "highlight.js": "11.11.1",
    "typescript": "6.0.3",
    "wrangler": "4.97.0"
  },
  "scripts": {
    "build": "node ./scripts/generate-manifest.mjs && gustwind --build --output ./build --progress",
    "build:cloudflare": "node ./scripts/generate-manifest.mjs && gustwind --build --output ./build --cache-from https://jster.net/ --progress",
    "build:validate": "node ./scripts/generate-manifest.mjs && gustwind --build --output ./build --validate --progress",
    "workers:deploy": "wrangler deploy ./worker.ts --assets=./build --config=./wrangler.toml",
    "workers:dev": "wrangler dev",
    "pages:dev": "wrangler dev",
    "check:links": "node ./scripts/check-links.mjs",
    "check:links:external": "node ./scripts/check-links.mjs --external",
    "audit:catalog": "node ./scripts/audit-catalog.mjs",
    "copy:css": "node ./scripts/copy-tailwind-css.mjs",
    "generate:manifest": "node ./scripts/generate-manifest.mjs",
    "fetch:new-jster": "node ./scripts/fetch-new-jster.mjs"
  },
  "keywords": [],
  "author": "Juho Vepsäläinen",
  "license": "MIT",
  "dependencies": {
    "htmlisp": "0.100.0",
    "satteri": "0.9.4",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  }
}
