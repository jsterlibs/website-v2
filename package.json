{
  "name": "jster-website-v2",
  "version": "0.0.0",
  "description": "jster.net website",
  "type": "module",
  "main": "index.js",
  "engines": {
    "node": ">=26.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260715.1",
    "@types/node": "25.9.1",
    "gustwind": "0.180.0",
    "highlight.js": "11.11.1",
    "typescript": "6.0.3",
    "wrangler": "4.111.0"
  },
  "scripts": {
    "build": "node ./scripts/generate-manifest.mjs && gustwind --build --output ./build --progress && npm run copy:css && npm run copy:catalog-data",
    "build:cloudflare": "node ./scripts/generate-manifest.mjs && gustwind --build --output ./build --cache-from https://jster.net/ --progress && npm run copy:css && npm run copy:catalog-data",
    "build:validate": "node ./scripts/generate-manifest.mjs && gustwind --build --output ./build --validate --progress && npm run copy:css && npm run copy:catalog-data",
    "workers:deploy": "wrangler deploy ./worker.ts --assets=./build --config=./wrangler.toml",
    "workers:dev": "wrangler dev --config=./wrangler.toml --env-file=/dev/null",
    "workers:types": "wrangler types --config=./wrangler.toml --env-file=/dev/null --include-runtime=false",
    "workers:types:check": "wrangler types --config=./wrangler.toml --env-file=/dev/null --include-runtime=false --check",
    "check:links": "node ./scripts/check-links.mjs",
    "check:links:external": "node ./scripts/check-links.mjs --external",
    "audit:catalog": "node ./scripts/audit-catalog.mjs",
    "copy:css": "node ./scripts/copy-tailwind-css.mjs",
    "copy:catalog-data": "node ./scripts/copy-catalog-data.mjs",
    "generate:manifest": "node ./scripts/generate-manifest.mjs",
    "fetch:new-jster": "node ./scripts/fetch-new-jster.mjs"
  },
  "keywords": [],
  "author": "Juho Vepsäläinen",
  "license": "MIT",
  "dependencies": {
    "htmlisp": "0.100.0",
    "satteri": "0.9.4",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  }
}
