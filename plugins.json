{
  "plugins": [
    {
      "path": "./node_modules/gustwind/plugins/meta/mod.js",
      "options": { "inputPath": "./site/meta.json" }
    },
    {
      "path": "./node_modules/gustwind/routers/config-router/mod.js",
      "options": {
        "dataSourcesPath": "./site/dataSources.ts",
        "routesPath": "./site/routes.json"
      }
    },
    {
      "path": "./node_modules/gustwind/plugins/htmlisp-renderer/mod.js",
      "options": {
        "components": [
          { "path": "./site/components" },
          { "path": "./site/layouts" }
        ],
        "globalUtilitiesPath": "./site/globalUtilities.ts"
      }
    },
    {
      "path": "./node_modules/gustwind/plugins/copy/mod.js",
      "options": {
        "inputPath": "./assets",
        "outputPath": "./assets"
      }
    },
    {
      "path": "./node_modules/gustwind/plugins/copy/mod.js",
      "options": {
        "inputPath": "./assets/img",
        "outputPath": "./img"
      }
    },
    {
      "path": "./node_modules/gustwind/plugins/script/mod.js",
      "options": {
        "scripts": [],
        "scriptsPath": []
      }
    },
    {
      "path": "./node_modules/gustwind/plugins/tailwind/mod.js",
      "options": {
        "cssPath": "./site/tailwind.css",
        "setupPath": "./site/tailwind.config.mjs"
      }
    },
    {
      "path": "./node_modules/gustwind/plugins/og/mod.js",
      "options": {
        "layout": "./site/layouts/og.html"
      }
    },
    { "path": "./site/plugins/seo.ts" },
    {
      "path": "./node_modules/gustwind/plugins/stats/mod.js"
    }
  ]
}
