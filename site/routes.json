{
  "/": {
    "meta": {
      "title": "JSter – JavaScript Catalog",
      "description": "JSter catalogues JavaScript libraries per purpose"
    },
    "layout": "siteIndex",
    "dataSources": {
      "parentCategories": {
        "operation": "getParentCategories",
        "parameters": []
      }
    }
  },
  "catalog": {
    "meta": {
      "title": "JSter – Catalog",
      "description": "JavaScript libraries per category"
    },
    "layout": "catalogIndex",
    "dataSources": {
      "parentCategories": {
        "operation": "getParentCategories",
        "parameters": []
      }
    }
  },
  "category": {
    "expand": {
      "matchBy": {
        "name": "categories",
        "indexer": {
          "operation": "indexCategories",
          "parameters": []
        },
        "slug": "id"
      },
      "dataSources": {
        "category": {
          "operation": "processCategory",
          "parameters": []
        }
      },
      "layout": "categoryPage",
      "meta": {
        "title": {
          "utility": "get",
          "parameters": ["context", "name"]
        },
        "description": {
          "utility": "get",
          "parameters": ["context", "description"]
        }
      }
    }
  },
  "tag": {
    "expand": {
      "matchBy": {
        "name": "tags",
        "indexer": {
          "operation": "indexTags",
          "parameters": []
        },
        "slug": "id"
      },
      "dataSources": {
        "category": {
          "operation": "processTag",
          "parameters": []
        }
      },
      "layout": "categoryPage",
      "meta": {
        "title": {
          "utility": "get",
          "parameters": ["context", "name"]
        },
        "description": {
          "utility": "get",
          "parameters": ["context", "description"]
        }
      }
    }
  },
  "about": {
    "meta": {
      "title": "JSter – About",
      "description": "About JSter"
    },
    "layout": "aboutPage"
  },
  "blog": {
    "layout": "blogIndex",
    "meta": {
      "title": "JSter – Blog",
      "description": "News relevant to JavaScript"
    },
    "dataSources": {
      "blogPosts": {
        "operation": "indexBlog",
        "parameters": []
      }
    },
    "expand": {
      "matchBy": {
        "name": "blogPosts",
        "indexer": {
          "operation": "indexBlog",
          "parameters": []
        },
        "slug": "id"
      },
      "dataSources": {
        "document": {
          "operation": "processBlogPost",
          "parameters": []
        }
      },
      "layout": "blogPage",
      "meta": {
        "title": {
          "utility": "get",
          "parameters": ["context", "document.title"]
        },
        "description": {
          "utility": "get",
          "parameters": ["context", "document.description"]
        }
      }
    }
  },
  "atom.xml": {
    "layout": "rssPage",
    "meta": {
      "title": "JSter",
      "description": "JSter blog"
    },
    "dataSources": {
      "blogPosts": {
        "operation": "indexBlog",
        "parameters": []
      }
    }
  }
}
